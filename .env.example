# Copy this file to .env and fill in your real API keys.
# Never commit .env to version control.

# OpenRouter — text generation (tagline, blog intro, social posts)
# Free models available — no billing required
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Hugging Face — FREE image generation via FLUX.1-schnell
# Get your free token at https://huggingface.co/settings/tokens
HF_API_KEY=your_hf_token_here

# ModelsLab — FREE credits for video generation (image-to-video)
# Sign up free at https://modelslab.com/dashboard/api-keys
MODELSLAB_API_KEY=your_modelslab_api_key_here

# OpenAI GPT Image API — paid fallback for image generation
# Only needed if you are NOT using HF_API_KEY
GPT_IMAGE_API_KEY=

# Runway — paid fallback for video generation (key must start with key_)
# Only needed if you are NOT using MODELSLAB_API_KEY
RUNWAY_API_KEY=

# Optional: override the default text model
# DEFAULT_TEXT_MODEL=google/gemma-4-31b-it:free
